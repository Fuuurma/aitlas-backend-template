# .env.example
# Copy to .env and fill in your values

# ─── Database (Neon) ───────────────────────────────────────────
# Pooled URL — runtime connections (has -pooler in hostname)
DATABASE_URL=postgresql://username:password@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Direct URL — migrations only (no -pooler in hostname)
DATABASE_URL_UNPOOLED=postgresql://username:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─── Auth ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-64-char-hex-secret-here

# ─── Internal service auth ─────────────────────────────────────
FURMA_INTERNAL_SECRET=your-internal-secret-here

# ─── BYOK encryption ───────────────────────────────────────────
# Generate: mix run -e "IO.puts(:crypto.strong_rand_bytes(32) |> Base.encode16(case: :lower))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# ─── App ───────────────────────────────────────────────────────
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE=your-phoenix-secret-key-base

# ─── MCP ───────────────────────────────────────────────────────
MCP_API_KEY=your-mcp-api-key

# ─── Environment ───────────────────────────────────────────────
MIX_ENV=dev